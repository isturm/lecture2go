<?xml version="1.0"?>
<!DOCTYPE routes PUBLIC "-//Liferay//DTD Friendly URL Routes 7.0.0//EN" "http://www.liferay.com/dtd/liferay-friendly-url-routes_7_0_0.dtd">

<routes>
    <route>
        <pattern>/{videoId}</pattern>
        <implicit-parameter name="mvcRenderCommandName">/embed</implicit-parameter>
    </route>
    <route>
        <pattern>/{videoId}/{startTime}/{endTime}</pattern>
        <implicit-parameter name="mvcRenderCommandName">/embed</implicit-parameter>
    </route>
</routes>